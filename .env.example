NODE_ENV=development
PORT=8081
DATABASE_URL=postgres://postgres:postgres@localhost:5432/polymarket_signal_lab
REDIS_URL=redis://localhost:6379
DATA_MODE=mock

# Polymarket official APIs / configurable bases
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_BASE_URL=https://data-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# Optional Telegram alerts
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Worker config
WORKER_ENABLED=true
WORKER_SYNC_MARKETS_INTERVAL_SECONDS=1800
WORKER_SYNC_PRICES_INTERVAL_SECONDS=120
WORKER_SYNC_WALLETS_INTERVAL_SECONDS=600
WORKER_CALC_WALLET_SCORES_INTERVAL_SECONDS=3600
WORKER_GENERATE_BUY_SIGNALS_INTERVAL_SECONDS=600
WORKER_MONITOR_SELL_SIGNALS_INTERVAL_SECONDS=120
WORKER_UPDATE_PAPER_TRADES_INTERVAL_SECONDS=120
WORKER_SEND_TELEGRAM_ALERTS_INTERVAL_SECONDS=60

# Optional websocket live market feed
POLYMARKET_WEBSOCKET_ENABLED=false
POLYMARKET_WEBSOCKET_URL=wss://clob.polymarket.com/ws
